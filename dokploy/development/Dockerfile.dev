FROM php:8.3-fpm

# 1. Define ARGs with defaults
ARG USER_ID=33
ARG GROUP_ID=33
ARG NODE_VERSION=20.x

# 2. Synchronize the www-data user ONLY if not root and not already 33
RUN if [ "${USER_ID}" -ne 33 ] && [ "${USER_ID}" -ne 0 ]; then \
	usermod -u ${USER_ID} www-data && \
	groupmod -g ${GROUP_ID} www-data; \
	fi

# 3. Install system dependencies
RUN apt-get update && apt-get install -y \
	curl unzip libpq-dev libonig-dev libzip-dev \
	&& docker-php-ext-install pdo_mysql pdo_pgsql mbstring zip

# 4. Install Xdebug (Dev only)
RUN pecl install xdebug && docker-php-ext-enable xdebug

# 5. Install Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# 6. Install Node.js
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION} | bash - \
	&& apt-get install -y nodejs

WORKDIR /var/www

# 7. Setup Directory & Permissions
# Fixed the logic to ensure directories exist and ownership is correct
RUN mkdir -p /var/www/storage /var/www/bootstrap/cache && \
	if [ "${USER_ID}" -ne 33 ] && [ "${USER_ID}" -ne 0 ]; then \
	chown -R www-data:www-data /var/www; \
	else \
	chown -R root:root /var/www; \
	fi

# 8. Set the execution user dynamically
# USER ${USER_ID}

# RUN chmod -R 775 /var/www/storage /var/www/bootstrap/cache

COPY --chmod=755 dokploy/development/entrypoint.dev.sh /usr/local/bin/entrypoint.sh

ENTRYPOINT ["entrypoint.sh"]